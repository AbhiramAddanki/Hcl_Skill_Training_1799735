#include <bits/stdc++.h>
using namespace std;

int main() {
    /* Enter your code here. Read input from STDIN. Print output to STDOUT */  
    string s;
    cin>>s;
    int n=s.length()-1;
    int count=1;
    string res="";
    for(int i=0;i<s.length()-1;i++){
      if(s[i]==s[i+1]){
        count+=1;
      }
      else{
        res+=s[i];
        res+=to_string(count);
        count=1;
      }
    } 
    res+=s[n];
    res+=to_string(count);
    cout<<res;
    return 0;
}